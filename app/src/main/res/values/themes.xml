<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.BumayeApp" parent="Theme.Material3.DayNight">
        <!-- 主要颜色配置 - Configuration des couleurs principales -->
        <item name="colorPrimary">@color/_v_primary_color</item>
        <item name="colorPrimaryVariant">#FF1976D2</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/_v_secondary_color</item>
        <item name="colorSecondaryVariant">#FFF57C00</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <item name="android:navigationBarColor">?attr/colorSurface</item>

        <!-- Background colors -->
        <item name="android:windowBackground">@color/_v_background_color</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black</item>

        <!-- Error color -->
        <item name="colorError">@color/_v_error_color</item>
        <item name="colorOnError">@color/white</item>

        <!-- Accent color for highlights -->
        <item name="colorAccent">@color/_v_accent_color</item>

        <!-- Toolbar and ActionBar styling -->
        <item name="actionBarTheme">@style/Theme.BumayeApp.ActionBar</item>
        <item name="toolbarStyle">@style/Widget.BumayeApp.Toolbar</item>
    </style>

    <style name="Theme.BumayeApp.ActionBar" parent="ThemeOverlay.Material3.Dark.ActionBar">
        <item name="colorControlNormal">@color/white</item>
        <item name="android:textColorPrimary">@color/white</item>
    </style>

    <style name="Widget.BumayeApp.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="titleTextColor">@color/white</item>
        <item name="subtitleTextColor">@color/white</item>
        <item name="android:background">?attr/colorPrimary</item>
    </style>

    <style name="Theme.BumayeApp.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.BumayeApp.AppBarOverlay" parent="ThemeOverlay.Material3.Dark.ActionBar" />

    <style name="Theme.BumayeApp.PopupOverlay" parent="ThemeOverlay.Material3.Light" />

    <!-- Custom button styles -->
    <style name="Widget.BumayeApp.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">?attr/colorPrimary</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:padding">16dp</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="Widget.BumayeApp.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">?attr/colorPrimary</item>
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- TextInputLayout styles -->
    <style name="Widget.BumayeApp.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">?attr/colorPrimary</item>
        <item name="hintTextColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:textColorHint">?attr/colorOnSurfaceVariant</item>
    </style>

    <!-- Card styles -->
    <style name="Widget.BumayeApp.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">?attr/colorSurface</item>
    </style>

    <!-- Typography styles -->
    <style name="TextAppearance.BumayeApp.Headline1" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextAppearance.BumayeApp.Headline2" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextAppearance.BumayeApp.Body1" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextAppearance.BumayeApp.Body2" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>
</resources>